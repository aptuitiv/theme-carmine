{
    "groups": [
        {
            "name": "Blog",
            "fields": [
                {
                    "name": "blogMainPageBannerHeading",
                    "label": "Banner heading",
                    "type": "text",
                    "defaultValue": "Blog"
                },
                {
                    "name": "blogMainPageBannerImage",
                    "label": "Banner Image",
                    "type": "image",
                    "description": "The image will be cropped on the page to match the Banner Bar settings. See Styles - Blocks Banner Bar - Banner Bar Images for more information.",
                    "path": "images",
                    "maxWidth": "2000",
                    "useAttributes": false
                }
            ]
        },
        {
            "name": "Breadcrumb",
            "fields": [
                {
                    "name": "showBreadcrumb",
                    "label": "Show Breadcrumb Text",
                    "type": "switch",
                    "defaultValue": "yes"
                }
            ]
        },
        {
            "name": "Customer Reviews & Ratings",
            "description": "Settings for the ratings",
            "fields": [
                {
                    "name": "customerRatingsBarReviewsLink",
                    "label": "URL to view reviews",
                    "type": "url",
                    "showLinkTextField": true
                },
                {
                    "name": "customerRatingsBarTotalReviews",
                    "label": "Total number of reviews",
                    "type": "text"
                },
                {
                    "name": "customerRatingsBarAverageRating",
                    "label": "Average rating",
                    "type": "text"
                }
            ]
        },
        {
            "name": "Footer",
            "description": "Content for the footer that is used on all pages",
            "fields": [
                {
                    "name": "footerShowNavigation",
                    "label": "Show navigation",
                    "type": "switch",
                    "defaultValue": "yes"
                },
                {
                    "name": "footerNavigationMenu",
                    "label": "Which navigation menu to use in the footer",
                    "type": "radio",
                    "defaultValue": "main",
                    "options": {
                        "main": "Same as the main navigation menu",
                        "footer": "Use the separate footer navigation menu"
                    }
                },
                {
                    "name": "footerShowAddress",
                    "label": "Show address",
                    "type": "switch",
                    "defaultValue": "yes"
                },
                {
                    "name": "footerShowEmail",
                    "label": "Show email",
                    "type": "switch",
                    "defaultValue": "no"
                },
                {
                    "name": "footerShowPhone",
                    "label": "Show phone number",
                    "type": "switch",
                    "defaultValue": "yes"
                },
                {
                    "name": "footerShowCredit",
                    "label": "Show Aptuitiv credit",
                    "type": "switch",
                    "defaultValue": "yes"
                }
            ]
        },
        {
            "name": "Header",
            "description": "Content for the header that is used on all pages.",
            "sidebarSize": "small",
            "groups": [
                {
                    "name": "Image Logo",
                    "fields": [
                        {
                            "name": "headerLogo",
                            "label": "Logo",
                            "type": "image",
                            "path": "images",
                            "render": {
                                "type": "replace",
                                "contentSelector": "#header-logo",
                                "template": "<div class=\"col-3-4 col-1-3-lg\" id=\"header-logo\"><a href=\"/\" title=\"return to home page\" class=\"Header-logoLink\"><img src=\"{{ url }}\" height=\"{{ imageHeight }}\" width=\"{{ imageWidth }}\" alt=\"{{ alt }}\" class=\"Header-logo\"></a></div>"
                            }
                        },
                        {
                            "name": "headerLogoWidth",
                            "label": "Logo width",
                            "type": "stepper",
                            "after": "px",
                            "defaultValue": "425",
                            "render": {
                                "type": "css-head",
                                "cssVariable": "--Header-logo-width",
                                "template": "{{ value }}px"
                            }
                        }
                    ]
                },
                {
                    "name": "Text Logo",
                    "description": "Alternative option to the image logo if none is available.",
                    "fields": [
                        {
                            "name": "headerTextLogo",
                            "label": "Text logo",
                            "type": "text",
                            "render": {
                                "type": "replace",
                                "contentSelector": "#header-logo",
                                "template": "<div class=\"col-3-4 col-1-3-lg\" id=\"header-logo\"><a href=\"/\" title=\"return to home page\" class=\"Header-logoLink\">{% if fields.headerLogo %}<img src=\"{{ fields.headerLogo.url }}\" class=\"Header-logo\">{% elseif value %}<div class=\"Header-textLogo\">{{ value }}</div>{% endif %}</a></div>"
                            }
                        }
                    ]
                },
                {
                    "name": "Information",
                    "fields": [
                        {
                            "name": "headerShowAddress",
                            "label": "Show address",
                            "type": "switch",
                            "defaultValue": "no"
                        },
                        {
                            "name": "headerShowPhone",
                            "label": "Show phone",
                            "type": "switch",
                            "defaultValue": "yes"
                        },
                        {
                            "name": "headerShowEmail",
                            "label": "Show email",
                            "type": "switch",
                            "defaultValue": "no"
                        },
                        {
                            "name": "headerShowSocial",
                            "label": "Show social icons",
                            "type": "switch",
                            "defaultValue": "yes"
                        },
                        {
                            "name": "headerShowHours",
                            "label": "Show hours of operation",
                            "type": "switch",
                            "defaultValue": "no"
                        },
                        {
                            "name": "headerHours",
                            "label": "Hours of operation",
                            "type": "textarea",
                            "description": "If you want to show the hours of operation in the header then enter them here."
                        }
                    ]
                },
                {
                    "name": "Sticky header behavior",
                    "fields": [
                        {
                            "name": "headerStickyEnabled",
                            "label": "Enable sticky header",
                            "type": "switch",
                            "description": "When enabled the header stays visible at the top of the page as the user scrolls.",
                            "defaultValue": "no"
                        },
                        {
                            "name": "headerStickyLogoScale",
                            "label": "Logo size when sticky",
                            "type": "stepper",
                            "description": "Percentage of the normal logo width while the header is sticky. 100 = unchanged, 75 = three-quarters size.",
                            "after": "%",
                            "defaultValue": "75",
                            "render": {
                                "type": "css-head",
                                "cssVariable": "--Header-sticky-logo-scale-pct",
                                "template": "{{ value }}"
                            }
                        },
                        {
                            "name": "headerStickyHideOnScroll",
                            "label": "Hide on scroll down (small screens)",
                            "type": "switch",
                            "description": "On small screens, hide the header when scrolling down and reveal it when scrolling up. Requires the sticky header to be enabled.",
                            "defaultValue": "no"
                        },
                        {
                            "name": "headerStickyHideSocial",
                            "label": "Hide social icons when sticky",
                            "type": "switch",
                            "defaultValue": "no"
                        },
                        {
                            "name": "headerStickyHideAddress",
                            "label": "Hide address when sticky",
                            "type": "switch",
                            "defaultValue": "yes"
                        },
                        {
                            "name": "headerStickyHidePhone",
                            "label": "Hide phone when sticky",
                            "type": "switch",
                            "defaultValue": "no"
                        },
                        {
                            "name": "headerStickyHideEmail",
                            "label": "Hide email when sticky",
                            "type": "switch",
                            "defaultValue": "yes"
                        },
                        {
                            "name": "headerStickyHideHours",
                            "label": "Hide hours when sticky",
                            "type": "switch",
                            "defaultValue": "yes"
                        },
                        {
                            "name": "headerStickyHideButtons",
                            "label": "Hide buttons when sticky",
                            "type": "switch",
                            "defaultValue": "no"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Header buttons",
            "sidebarSize": "medium",
            "fields": [
                {
                    "name": "headerShowButtons",
                    "label": "Show buttons",
                    "type": "switch",
                    "defaultValue": "yes"
                },
                {
                    "name": "headerButtons",
                    "label": "Buttons",
                    "type": "repeatingGrid",
                    "itemName": "Button",
                    "children": [
                        {
                            "name": "button",
                            "label": "Button",
                            "type": "url",
                            "showLinkTextField": true,
                            "linkTextFieldLabel": "Button text"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Social Icons",
            "description": "Set the links and icons to use for your social networks in the footer of each page.",
            "sidebarSize": "medium",
            "fields": [
                {
                    "name": "social",
                    "label": "Social Networks",
                    "type": "repeatingGrid",
                    "itemName": "Social Network",
                    "children": [
                        {
                            "name": "icon",
                            "label": "Icon",
                            "type": "select",
                            "options": {
                                "facebook": "Facebook",
                                "google": "Google",
                                "instagram": "Instagram",
                                "linkedin": "LinkedIn",
                                "pinterest": "Pinterest",
                                "tiktok": "TikTok",
                                "whatsapp": "WhatsApp",
                                "x": "X (Twitter)",
                                "youtube": "YouTube"
                            },
                            "columnWidth": "1fr"
                        },
                        {
                            "name": "url",
                            "label": "URL to your page on this social network",
                            "type": "text",
                            "columnWidth": "2fr"
                        }
                    ]
                }
            ]
        }
    ]
}
